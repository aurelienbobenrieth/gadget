{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gadget ESLint plugin",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "about", "getting-started/installation", "getting-started/configuration"]
          },
          {
            "group": "Concepts",
            "pages": ["guides/how-rules-apply"]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Configurations",
            "pages": ["reference/configurations"]
          },
          {
            "group": "Options and params",
            "pages": [
              "reference/rules/action-no-invalid-options",
              "reference/rules/action-no-invalid-params",
              "reference/rules/action-no-invalid-timeout-ms",
              "reference/rules/action-require-explicit-return-type",
              "reference/rules/action-require-timeout-ms-comment",
              "reference/rules/global-action-no-action-type",
              "reference/rules/model-action-invalid-action-type",
              "reference/rules/model-action-no-invalid-trigger",
              "reference/rules/model-action-no-transactional-timeout-mismatch"
            ]
          },
          {
            "group": "Runtime safety",
            "pages": [
              "reference/rules/action-no-await-handle-result-in-action",
              "reference/rules/action-no-empty-on-success",
              "reference/rules/action-no-return-value-in-on-success",
              "reference/rules/action-require-action-run-type",
              "reference/rules/action-require-run-with-on-success"
            ]
          },
          {
            "group": "Enqueue safety",
            "pages": [
              "reference/rules/action-no-enqueue-max-concurrency-exceeded",
              "reference/rules/action-no-implicit-enqueue-retries"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/package/@aurelienbbn/eslint-plugin-gadget",
          "icon": "package"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/aurelienbobenrieth/gadget/tree/main/packages/eslint-plugin-gadget",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/aurelienbobenrieth/gadget"
      }
    ],
    "primary": {
      "type": "button",
      "label": "npm",
      "href": "https://www.npmjs.com/package/@aurelienbbn/eslint-plugin-gadget"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/aurelienbobenrieth/gadget"
    }
  }
}
